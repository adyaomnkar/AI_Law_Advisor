# AI Law Advisor - Environment Variables
# Copy this file to .env and fill in your API keys

# LLM Provider (set at least one)
# Get Gemini key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get Claude key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Database (optional - defaults to SQLite for development)
# DATABASE_URL=postgresql://user:password@localhost:5432/law_advisor

# Server
PORT=8000
FRONTEND_URL=http://localhost:3000
