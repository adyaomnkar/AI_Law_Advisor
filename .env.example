# AI Law Advisor - Environment Variables
# Copy this file to .env and fill in your API keys

# LLM Provider (set at least one)
# Get Gemini key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Get Claude key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# PostgreSQL (optional - falls back to SQLite if not configured)
PG_HOST=localhost
PG_PORT=5432
PG_DB=law_advisor
PG_USER=postgres
PG_PASS=your_password_here

# Server
PORT=8000
FRONTEND_URL=http://localhost:3000
